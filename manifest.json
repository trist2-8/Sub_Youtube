{
  "manifest_version": 3,
  "name": "Subtitle Grabber",
  "version": "4.7.0",
  "description": "Per-site profile memory release: giữ lõi YouTube + Netflix + pin, thêm nhớ riêng settings cho từng nền tảng và diagnostics rõ hơn.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://m.youtube.com/*",
    "https://music.youtube.com/*",
    "https://netflix.com/*",
    "https://www.netflix.com/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_title": "Subtitle Grabber",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
