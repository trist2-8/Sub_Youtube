{
  "manifest_version": 3,
  "name": "Subtitle Grabber",
  "version": "4.6.1",
  "description": "Merge-safe 4.6.1 release: giữ lõi YouTube + Netflix + pin ổn định, thêm diagnostics, sync profile và YouTube lead.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://m.youtube.com/*",
    "https://music.youtube.com/*",
    "https://netflix.com/*",
    "https://www.netflix.com/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_title": "Subtitle Grabber",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}