{
  "manifest_version": 3,
  "name": "YT Subtitle Grabber",
  "version": "4.12.0",
  "description": "Subtitle workspace with tighter pin UI, smarter YouTube time-sync, and an upgraded Netflix study flow inspired by Language Reactor.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "downloads",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*",
    "https://www.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YT Subtitle Grabber",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
