{
  "manifest_version": 3,
  "name": "YT Subtitle Grabber",
  "version": "1.1.0",
  "description": "Lấy phụ đề từ video YouTube đang mở và xuất ra TXT, SRT hoặc VTT.",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "downloads", "storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YT Subtitle Grabber",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }

}