{
  "manifest_version": 3,
  "name": "YT Subtitle Grabber",
  "version": "2.1.5",
  "description": "Ưu tiên phụ đề gốc theo video, đổi ngôn ngữ ổn định hơn, hỗ trợ song ngữ, export và ghi nhớ tùy chọn.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "downloads",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "action": {
    "default_title": "YT Subtitle Grabber",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}